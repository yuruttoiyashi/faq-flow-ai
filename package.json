{
  "name": "faq-flow-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
  "dev": "vite",
  "build": "tsc -b && vite build",
  "preview": "vite preview",
  "pages:dev": "npm run build && wrangler pages dev --ai=AI",
  "pages:deploy": "npm run build && wrangler pages deploy --project-name=faq-flow-ai --branch main",
  "db:local": "wrangler d1 execute faq-flow-ai-db --local --file=./schema.sql",
  "db:remote": "wrangler d1 execute faq-flow-ai-db --remote --file=./schema.sql"
},
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260527.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "wrangler": "latest"
  }
}
